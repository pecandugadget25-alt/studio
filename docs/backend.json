{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Informasi profil pengguna ETHNO-ARITH dengan fitur gamifikasi.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nama": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "peran": { "type": "string", "enum": ["siswa", "guru", "admin", "peneliti"] },
        "level": { "type": "number" },
        "poin": { "type": "number" },
        "completedModules": { "type": "array", "items": { "type": "string" } },
        "completedComics": { "type": "array", "items": { "type": "string" } },
        "badges": { "type": "array", "items": { "type": "string" } },
        "tanggalDaftar": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nama", "email", "peran"]
    },
    "StudentProgress": {
      "title": "Student Progress",
      "description": "Detail progress belajar siswa per modul.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "moduleId": { "type": "string" },
        "status": { "type": "string" },
        "lastAccessed": { "type": "string", "format": "date-time" }
      }
    },
    "ScanHistory": {
      "title": "AR Scan History",
      "description": "Riwayat penggunaan AR Scanner oleh siswa.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "markerId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Koleksi profil pengguna."
    },
    "/student_progress/{progressId}": {
      "schema": "StudentProgress",
      "description": "Progres belajar siswa."
    },
    "/scan_history/{historyId}": {
      "schema": "ScanHistory",
      "description": "Riwayat scan AR."
    }
  }
}
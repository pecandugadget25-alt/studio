{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Informasi profil pengguna ETHNO-ARITH dengan fitur gamifikasi.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nama": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "peran": { "type": "string", "enum": ["siswa", "guru", "admin", "peneliti"] },
        "level": { "type": "number" },
        "poin": { "type": "number" },
        "scanCount": { "type": "number", "description": "Total pemindaian QR yang berhasil." },
        "completedModules": { "type": "array", "items": { "type": "string" } },
        "completedComics": { "type": "array", "items": { "type": "string" } },
        "badges": { "type": "array", "items": { "type": "string" } },
        "tanggalDaftar": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nama", "email", "peran"]
    },
    "ScanLog": {
      "title": "Smart QR Scan Log",
      "description": "Log setiap kali siswa melakukan pemindaian QR Code.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "studentName": { "type": "string" },
        "qrType": { "type": "string", "enum": ["video", "module", "comic", "quiz", "ar", "unknown"] },
        "qrValue": { "type": "string" },
        "source": { "type": "string", "enum": ["camera", "gallery"] },
        "xpEarned": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "User Activity Log",
      "description": "Log aktivitas harian siswa untuk monitoring guru.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "type": { "type": "string", "enum": ["quiz", "comic", "ar", "module", "scan"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Koleksi profil pengguna."
    },
    "/scan_logs/{logId}": {
      "schema": "ScanLog",
      "description": "Riwayat pemindaian QR Smart."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Log aktivitas siswa."
    }
  }
}
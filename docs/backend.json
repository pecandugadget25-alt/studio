
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Informasi profil pengguna ETHNO-ARITH dengan fitur gamifikasi.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nama": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "peran": { "type": "string", "enum": ["siswa", "guru", "admin", "peneliti"] },
        "level": { "type": "number" },
        "poin": { "type": "number" },
        "scanCount": { "type": "number" },
        "completedModules": { "type": "array", "items": { "type": "string" } },
        "completedComics": { "type": "array", "items": { "type": "string" } },
        "completedVideos": { "type": "array", "items": { "type": "string" } },
        "badges": { "type": "array", "items": { "type": "string" } },
        "tanggalDaftar": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nama", "email", "peran"]
    },
    "Activity": {
      "title": "User Activity Log",
      "description": "Log aktivitas harian siswa untuk monitoring.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "activityType": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "xp": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "StudentAIAnalysis": {
      "title": "Student AI Analysis",
      "description": "Hasil analisis mendalam berbasis AI untuk individu siswa.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "learningProfile": { "type": "string" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "narrative": { "type": "string" },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "riskLevel": { "type": "string", "enum": ["aman", "perhatian", "risiko"] },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Koleksi profil pengguna."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Log aktivitas siswa."
    },
    "/student_ai_analysis/{analysisId}": {
      "schema": "StudentAIAnalysis",
      "description": "Riwayat analisis AI siswa oleh guru."
    }
  }
}

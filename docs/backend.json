
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Informasi profil pengguna ETHNO-ARITH dengan fitur gamifikasi.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nama": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "peran": { "type": "string", "enum": ["siswa", "guru", "admin", "peneliti"] },
        "level": { "type": "number" },
        "poin": { "type": "number" },
        "scanCount": { "type": "number", "description": "Total pemindaian QR yang berhasil." },
        "completedModules": { "type": "array", "items": { "type": "string" } },
        "completedComics": { "type": "array", "items": { "type": "string" } },
        "completedVideos": { "type": "array", "items": { "type": "string" }, "description": "Daftar ID video yang sudah selesai ditonton." },
        "badges": { "type": "array", "items": { "type": "string" } },
        "tanggalDaftar": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nama", "email", "peran"]
    },
    "ScanLog": {
      "title": "Universal Scan Log",
      "description": "Log pindaian QR edukatif universal.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "qrType": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "source": { "type": "string" },
        "xpEarned": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "User Activity Log",
      "description": "Log aktivitas harian siswa untuk monitoring guru.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "type": { "type": "string", "enum": ["quiz", "comic", "ar", "module", "scan", "video"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Koleksi profil pengguna."
    },
    "/scan_logs/{logId}": {
      "schema": "ScanLog",
      "description": "Riwayat pemindaian QR universal."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Log aktivitas siswa."
    }
  }
}
